{
  "name": "io-auto-mode",
  "version": "0.1.0",
  "description": "Exec security classifier for AI coding agents — hybrid static + LLM. Cursor + Claude Code + OpenClaw.",
  "type": "module",
  "license": "MIT",
  "author": "Simon Dixon (https://inkie.ink)",
  "homepage": "https://github.com/simon-inkie/io-auto-mode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simon-inkie/io-auto-mode.git"
  },
  "bugs": {
    "url": "https://github.com/simon-inkie/io-auto-mode/issues"
  },
  "keywords": [
    "claude-code",
    "cursor",
    "openclaw",
    "ai-agents",
    "agentic",
    "ai-security",
    "prompt-injection",
    "permission-classifier",
    "classifier",
    "mcp"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "io-auto-mode-cursor-shell": "adapters/cursor/dist/hook.js",
    "io-auto-mode-cursor-file": "adapters/cursor/dist/file-hook.js",
    "io-auto-mode-cursor-prompt": "adapters/cursor/dist/prompt-hook.js",
    "io-auto-mode-cc-shell": "adapters/claude-code/dist/hook.js",
    "io-auto-mode-cc-file": "adapters/claude-code/dist/file-hook.js"
  },
  "files": [
    "adapters/cursor/dist/",
    "adapters/cursor/prompts/",
    "adapters/cursor/package.json",
    "adapters/claude-code/dist/",
    "adapters/claude-code/prompts/",
    "adapters/claude-code/package.json",
    "README.md",
    "LICENSE",
    "INSTALL.md"
  ],
  "scripts": {
    "benchmark": "tsx benchmarks/runner.ts",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "build": "node scripts/build.mjs",
    "prepublishOnly": "node scripts/build.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "openclaw": "^2026.4.2"
  }
}
